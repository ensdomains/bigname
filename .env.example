# PostgreSQL service settings for docker-compose and local binaries.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=bigname
POSTGRES_USER=bigname
POSTGRES_PASSWORD=bigname
DATABASE_URL=postgresql://bigname:bigname@127.0.0.1:5432/bigname
BIGNAME_DATABASE_URL=postgresql://bigname:bigname@127.0.0.1:5432/bigname
# Per-service primary pool ceiling; the API reserves one additional readiness connection.
BIGNAME_DATABASE_MAX_CONNECTIONS=10

# API bind address for local bigname-api serve.
BIGNAME_API_BIND_ADDR=127.0.0.1:3000
# API live execution RPC entries, as comma-delimited <chain>=<url> pairs.
# BIGNAME_API_CHAIN_RPC_URLS=ethereum-mainnet=http://127.0.0.1:8545
# Maximum addresses accepted by the native identity batch endpoint.
BIGNAME_API_IDENTITY_BATCH_LIMIT=1000
# Maximum inputs accepted by the v2 lookup endpoint.
BIGNAME_API_LOOKUP_BATCH_LIMIT=1000
# Whole-request deadline for every API route, in milliseconds.
BIGNAME_API_REQUEST_TIMEOUT_MS=30000
# PostgreSQL statement timeout for primary API request-pool connections, in milliseconds.
BIGNAME_API_DB_STATEMENT_TIMEOUT_MS=25000
# Process-wide request concurrency ceiling; /healthz bypasses it.
BIGNAME_API_MAX_IN_FLIGHT=1024
# Independent /healthz concurrency ceiling, reserved outside the process-wide ceiling.
BIGNAME_API_HEALTH_MAX_IN_FLIGHT=4
# Separate verified-execution request concurrency ceiling.
BIGNAME_API_VERIFIED_EXECUTION_MAX_IN_FLIGHT=128
# API-triggered execution JSON-RPC connect and total deadlines, in milliseconds.
BIGNAME_API_RPC_CONNECT_TIMEOUT_MS=2000
BIGNAME_API_RPC_TIMEOUT_MS=8000
# Verified-execution token bucket keyed by IPv4 address or IPv6 /64. A zero rate disables it.
BIGNAME_API_VERIFIED_RATE_LIMIT_PER_SECOND=0
BIGNAME_API_VERIFIED_RATE_LIMIT_BURST=10
BIGNAME_API_VERIFIED_RATE_LIMIT_MAX_CLIENTS=65536
# Trust X-Forwarded-For only when every public request reaches the API through a trusted edge.
BIGNAME_API_TRUST_X_FORWARDED_FOR=false
# Emit JSON logs when this variable is present; leave commented for compact text logs.
# BIGNAME_LOG_JSON=1

# Indexer live-ingestion settings.
# The manifest root selects exactly one deployment profile for the runtime.
# Use manifests/mainnet for mainnet or manifests/sepolia for the ENSv2 Sepolia profile.
BIGNAME_INDEXER_MANIFESTS_ROOT=manifests/mainnet
# Poll interval in seconds for live indexer loops.
BIGNAME_INDEXER_POLL_INTERVAL_SECS=5
# Maximum watched addresses verified per chain by one code-observation sweep tick.
BIGNAME_INDEXER_RAW_CODE_BASELINE_MAX_ADDRESSES_PER_TICK=2048
# Block span for hash-pinned backfill ranges.
BIGNAME_INDEXER_HASH_PINNED_BACKFILL_CHUNK_BLOCKS=1024
# Maximum sparse backfill logs pushed in one raw-only payload.
BIGNAME_INDEXER_HASH_PINNED_BACKFILL_MAX_LOGS_PER_PUSH=10000
# Legacy alias for BIGNAME_INDEXER_HASH_PINNED_BACKFILL_MAX_LOGS_PER_PUSH.
# BIGNAME_INDEXER_HASH_PINNED_BACKFILL_MAX_LOGS_PER_RANGE=10000
# Adapter sync mode after hash-pinned backfill: auto, always, or never.
BIGNAME_INDEXER_HASH_PINNED_BACKFILL_ADAPTER_SYNC=auto
# Number of automatic bootstrap backfill workers.
BIGNAME_INDEXER_BOOTSTRAP_BACKFILL_WORKERS=0
# Block span for automatic bootstrap child ranges.
BIGNAME_INDEXER_BOOTSTRAP_BACKFILL_RANGE_BLOCKS=50000
# Target raw logs per ENSv1 startup page; ownership/control pages keep dense blocks whole.
BIGNAME_INDEXER_STARTUP_DISCOVERY_PAGE_LOGS=100000
# Enable normalized-event replay catch-up in the indexer.
BIGNAME_INDEXER_NORMALIZED_REPLAY_CATCHUP_ENABLED=true
# Block span for normalized-event replay catch-up.
BIGNAME_INDEXER_NORMALIZED_REPLAY_CATCHUP_CHUNK_BLOCKS=262144
# Maximum logs consumed by one normalized-event replay catch-up chunk.
BIGNAME_INDEXER_NORMALIZED_REPLAY_CATCHUP_MAX_LOGS_PER_CHUNK=100000
# Poll interval in seconds for normalized-event replay catch-up.
BIGNAME_INDEXER_NORMALIZED_REPLAY_CATCHUP_POLL_INTERVAL_SECS=5
# Drop and rebuild projection indexes around normalized replay catch-up.
BIGNAME_INDEXER_NORMALIZED_REPLAY_DEFER_PROJECTION_INDEXES=true
# Retain optional block-header audit fields during intake.
BIGNAME_INDEXER_RETAIN_HEADER_AUDIT_FIELDS=false
# Backfill source selection: hash-pinned, coinbase-sql, or auto.
BIGNAME_INDEXER_BACKFILL_SOURCE=hash-pinned

# Comma-delimited <chain>=<url> entries for active watched chains.
# Current bootstrap RPC support accepts http:// and https:// endpoints.
# Example local node configuration:
# BIGNAME_INDEXER_CHAIN_RPC_URLS=ethereum-mainnet=http://127.0.0.1:8545,base-mainnet=http://127.0.0.1:9545
# Optional receipt fallback RPC entries, as comma-delimited <chain>=<url> pairs.
# BIGNAME_INDEXER_CHAIN_RPC_RECEIPT_FALLBACK_URLS=ethereum-mainnet=http://127.0.0.1:8546
# Optional historical-code fallback RPC entries, as comma-delimited <chain>=<url> pairs.
# BIGNAME_INDEXER_CHAIN_RPC_CODE_FALLBACK_URLS=ethereum-mainnet=https://archive.example/ethereum
# Optional local Reth database entries, as comma-delimited <chain>=<reth-datadir> pairs.
# BIGNAME_INDEXER_CHAIN_RETH_DB_SOURCES=ethereum-mainnet=/var/lib/reth
# Maximum JSON-RPC batch items sent in one request.
BIGNAME_INDEXER_JSON_RPC_BATCH_ITEM_LIMIT=32
# Maximum concurrent JSON-RPC batch requests.
BIGNAME_INDEXER_JSON_RPC_BATCH_CONCURRENCY=1
# Optional extra legacy reverse resolver addresses with event-silent writes.
# BIGNAME_INDEXER_EVENT_SILENT_REVERSE_RESOLVER_ADDRESSES=0x...
# Coinbase SQL endpoint mapping for historical Base backfill.
# BIGNAME_INDEXER_COINBASE_SQL_URLS=base-mainnet=default
# Environment variable name holding the Coinbase SQL API key id.
BIGNAME_INDEXER_COINBASE_SQL_API_KEY_ID_ENV=COINBASE_CDP_SQL_API_KEY_ID
# Environment variable name holding the Coinbase SQL API key secret.
BIGNAME_INDEXER_COINBASE_SQL_API_KEY_SECRET_ENV=COINBASE_CDP_SQL_API_KEY_SECRET
# Initial Coinbase SQL window size in blocks.
BIGNAME_INDEXER_COINBASE_SQL_INITIAL_WINDOW_BLOCKS=1024
# Maximum Coinbase SQL window size in blocks.
BIGNAME_INDEXER_COINBASE_SQL_MAX_WINDOW_BLOCKS=8192
# Coinbase SQL row page limit per request.
BIGNAME_INDEXER_COINBASE_SQL_PAGE_LIMIT=10000
# Coinbase SQL query character limit.
BIGNAME_INDEXER_COINBASE_SQL_QUERY_CHAR_LIMIT=10000
# Coinbase SQL query timeout in seconds.
BIGNAME_INDEXER_COINBASE_SQL_QUERY_TIMEOUT_SECS=30
# Coinbase SQL request rate limit in queries per second.
BIGNAME_INDEXER_COINBASE_SQL_RATE_LIMIT_QPS=5
# Coinbase SQL validation mode.
BIGNAME_INDEXER_COINBASE_SQL_VALIDATION_MODE=full
# Coinbase SQL worker count.
BIGNAME_INDEXER_COINBASE_SQL_WORKERS=1
# Coinbase SQL per-job range size; 0 lets the runner choose.
BIGNAME_INDEXER_COINBASE_SQL_RANGE_BLOCKS=0
# Coinbase SQL credential value for the default key-id env name.
# COINBASE_CDP_SQL_API_KEY_ID=replace-me
# Coinbase SQL credential value for the default key-secret env name.
# COINBASE_CDP_SQL_API_KEY_SECRET=replace-me
# Deployment profile override for indexer operational subcommands.
# BIGNAME_INDEXER_DEPLOYMENT_PROFILE=mainnet
# Ops catch-up child range size in blocks.
BIGNAME_INDEXER_OPS_CATCHUP_CHUNK_BLOCKS=32
# Run ops catch-up continuously when true.
BIGNAME_INDEXER_OPS_CATCHUP_FOLLOW=false
# Optional bounded number of ops catch-up follow iterations.
# BIGNAME_INDEXER_OPS_CATCHUP_FOLLOW_ITERATIONS=1
# Poll interval in seconds between ops catch-up follow iterations.
BIGNAME_INDEXER_OPS_CATCHUP_FOLLOW_POLL_INTERVAL_SECS=30
# Lease duration in seconds for ops catch-up backfill ranges.
BIGNAME_INDEXER_OPS_CATCHUP_LEASE_DURATION_SECS=300
# Optional maximum PostgreSQL size in bytes before ops catch-up pauses.
# BIGNAME_INDEXER_OPS_CATCHUP_POSTGRES_MAX_BYTES=1099511627776
# Minimum writable free disk bytes required by ops catch-up.
BIGNAME_INDEXER_OPS_CATCHUP_MIN_FREE_DISK_BYTES=0
# Disk path checked by the ops catch-up capacity guard.
BIGNAME_INDEXER_OPS_CATCHUP_DISK_PATH=.
# Estimated bytes per block used by the ops catch-up capacity guard.
BIGNAME_INDEXER_OPS_CATCHUP_ESTIMATED_BYTES_PER_BLOCK=0
# Block batch size for post-replay live adapter backlog sync.
BIGNAME_INDEXER_LIVE_ADAPTER_BACKLOG_BLOCK_BATCH_SIZE=1

# Worker loop interval in seconds.
BIGNAME_WORKER_POLL_INTERVAL_SECS=5
# Optional worker RPC for ENSv1 legacy text hydration during projection replay/apply.
# BIGNAME_WORKER_CHAIN_RPC_URLS=ethereum-mainnet=http://127.0.0.1:8545
# Multicall3 address for projection-owned text hydration.
BIGNAME_WORKER_TEXT_HYDRATION_MULTICALL3_ADDRESS=0xcA11bde05977b3631167028862bE2a173976CA11
# Batch size for projection-owned text hydration.
BIGNAME_WORKER_TEXT_HYDRATION_BATCH_SIZE=250
# Optional extra legacy reverse resolver addresses for primary-name hydration.
# BIGNAME_WORKER_PRIMARY_NAME_LEGACY_REVERSE_RESOLVER_ADDRESSES=0x...
# Multicall3 address for legacy reverse primary-name hydration.
BIGNAME_WORKER_PRIMARY_NAME_LEGACY_REVERSE_HYDRATION_MULTICALL3_ADDRESS=0xcA11bde05977b3631167028862bE2a173976CA11
# Batch size for legacy reverse primary-name hydration.
BIGNAME_WORKER_PRIMARY_NAME_LEGACY_REVERSE_HYDRATION_BATCH_SIZE=250

# Optional alternate test database URL for DB-backed Rust tests.
# BIGNAME_TEST_DATABASE_URL=postgresql://bigname:bigname@127.0.0.1:55432/bigname
# Optional Reth datadir for ignored local Reth comparison tests.
# BIGNAME_INDEXER_TEST_RETH_DB_DATADIR=/var/lib/reth
# Optional Ethereum RPC URL for ignored local Reth comparison tests.
# BIGNAME_INDEXER_TEST_ETHEREUM_RPC_URL=http://127.0.0.1:8545
# Optional comma-delimited block list for ignored local Reth comparison tests.
# BIGNAME_INDEXER_TEST_RETH_COMPARE_BLOCKS=17000000,17000001
