# PostgreSQL service settings for docker-compose and local binaries.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=bigname
POSTGRES_USER=bigname
POSTGRES_PASSWORD=bigname
DATABASE_URL=postgresql://bigname:bigname@127.0.0.1:5432/bigname
BIGNAME_DATABASE_URL=postgresql://bigname:bigname@127.0.0.1:5432/bigname
BIGNAME_DATABASE_MAX_CONNECTIONS=10

# MinIO provides the local S3-compatible API and console.
# Keep these aligned so the container credentials match client credentials.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=bigname
MINIO_ROOT_PASSWORD=bigname-secret
AWS_ACCESS_KEY_ID=bigname
AWS_SECRET_ACCESS_KEY=bigname-secret
AWS_REGION=us-east-1
AWS_ENDPOINT_URL_S3=http://127.0.0.1:9000
S3_BUCKET=bigname-dev
S3_FORCE_PATH_STYLE=true

# Indexer live-ingestion settings.
# The manifest root selects exactly one deployment profile for the runtime.
# Use manifests for mainnet or manifests-sepolia-dev for the ENSv2 Sepolia dev profile.
BIGNAME_INDEXER_MANIFESTS_ROOT=manifests
BIGNAME_INDEXER_POLL_INTERVAL_SECS=5
BIGNAME_INDEXER_HASH_PINNED_BACKFILL_CHUNK_BLOCKS=1024

# Comma-delimited <chain>=<url> entries for active watched chains.
# Current bootstrap RPC support accepts http:// endpoints only.
# Example local node configuration:
# BIGNAME_INDEXER_CHAIN_RPC_URLS=ethereum-mainnet=http://127.0.0.1:8545,base-mainnet=http://127.0.0.1:9545
